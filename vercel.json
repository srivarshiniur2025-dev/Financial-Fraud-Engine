{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "services": {
    "streamlit": {
      "root": ".",
      "entrypoint": "Dockerfile.vercel"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "streamlit"
      }
    }
  ]
}
